{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Code-review routing verdict",
  "type": "object",
  "required": ["status", "issues", "summary"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "escalate"]
    },
    "summary": {
      "type": "string",
      "maxLength": 280
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "description", "fix_instruction"],
        "properties": {
          "severity": { "type": "string", "enum": ["minor", "major", "critical"] },
          "description": { "type": "string" },
          "fix_instruction": { "type": "string" }
        }
      }
    }
  }
}
